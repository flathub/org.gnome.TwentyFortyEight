{
    "app-id": "org.gnome.TwentyFortyEight",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command": "gnome-2048",
    "finish-args": [
        "--socket=wayland",
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri"
    ],
    "cleanup": [
        "/share/man"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin",
        "env": {
            "CARGO_HOME": "/run/build/rust-flatpak/cargo"
        },
        "test-args": [
            "--socket=x11"
        ]
    },
    "modules": [
        {
            "name": "gnome-2048",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://gitlab.gnome.org/GNOME/gnome-2048.git",
                    "commit": "ac914aa5b4b9e6bdb936465afd903d46022d76b4"
                },
                "generated-sources.json",
                {
                    "type": "shell",
                    "commands": [
                        "mkdir .cargo",
                        "cp cargo/config .cargo/"
                    ]
                }
            ]
        }
    ]
}
